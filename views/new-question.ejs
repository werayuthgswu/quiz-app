<!DOCTYPE html>
<html>
<head>
  <title>Add Question to <%= quiz.title %></title>
  <style>
    body { font-family: Arial, sans-serif; margin: 40px; }
    input, select, button { padding: 10px; margin: 5px 0; }
    input[type="text"] { width: 400px; }
    .btn { background: #007bff; color: white; border: none; border-radius: 4px; }
  </style>
</head>
<body>
  <h1>Add Question to "<%= quiz.title %>"</h1>
  <form method="POST" action="/quiz/<%= quiz.id %>/question">
    <div>
      <label>Question:</label><br>
      <input type="text" name="text" required>
    </div>
    <div>
      <label>Option 1:</label><br>
      <input type="text" name="option1" required>
    </div>
    <div>
      <label>Option 2:</label><br>
      <input type="text" name="option2" required>
    </div>
    <div>
      <label>Option 3:</label><br>
      <input type="text" name="option3" required>
    </div>
    <div>
      <label>Option 4:</label><br>
      <input type="text" name="option4" required>
    </div>
    <div>
      <label>Correct Answer:</label><br>
      <select name="correct" required>
        <option value="0">Option 1</option>
        <option value="1">Option 2</option>
        <option value="2">Option 3</option>
        <option value="3">Option 4</option>
      </select>
    </div>
    <button type="submit" class="btn">Add Question</button>
  </form>
  <a href="/quiz/<%= quiz.id %>">Back to Quiz</a>
</body>
</html>
